{
  "name": "truehire",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter web start",
    "lint": "pnpm -r lint",
    "biome:lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:e2e:local": "node scripts/test-e2e-local.mjs",
    "db:generate": "pnpm --filter @truehire/db generate",
    "db:migrate": "pnpm --filter @truehire/db migrate",
    "db:studio": "pnpm --filter @truehire/db studio",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@vitest/coverage-v8": "4.1.5",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "next": "16.2.4",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "node scripts/secret-scan.mjs"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}

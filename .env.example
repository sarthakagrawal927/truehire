# ──────────── Auth.js (NextAuth v5) ────────────
# openssl rand -base64 32
AUTH_SECRET=
# Only needed in prod (Auth.js infers at :3000 in dev)
AUTH_URL=http://localhost:3000

# ──────────── GitHub OAuth ────────
# Create at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
#                https://<prod-domain>/api/auth/callback/github
# Scopes required (requested in code): read:user, user:email, public_repo
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ──────────── GitHub API (ingest) ─
# App-wide PAT used for batch weekly recomputes (OAuth tokens are per-user
# and expire). Fine-grained PAT with public_repo + read:user scope.
GITHUB_API_TOKEN=

# ──────────── Database ────────────
# Dev — local libsql file
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=

# Prod — Turso (provision with `turso db create truehire`)
# DATABASE_URL=libsql://<db-name>-<org>.turso.io
# DATABASE_AUTH_TOKEN=

# ──────────── App ────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

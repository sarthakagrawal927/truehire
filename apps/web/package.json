{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "cf:build": "next build --webpack && node scripts/run-inline-critical-css.mjs && opennextjs-cloudflare build --skipNextBuild && opennextjs-cloudflare populateCache local && pnpm --filter ./landing-astro build && node scripts/run-overlay-astro-landing.mjs",
    "validate:env:deploy": "node scripts/validate-env.mjs deploy",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "pnpm validate:env:deploy && opennextjs-cloudflare deploy",
    "cf:upload": "opennextjs-cloudflare upload",
    "seed:anchors": "tsx scripts/seed-anchors.ts"
  },
  "dependencies": {
    "@auth/core": "0.37.4",
    "@auth/drizzle-adapter": "1.11.2",
    "@octokit/rest": "22.0.1",
    "@opennextjs/cloudflare": "1.19.4",
    "@paralleldrive/cuid2": "3.3.0",
    "@saas-maker/feedback": "^0.2.1",
    "@truehire/core": "workspace:*",
    "@truehire/db": "workspace:*",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.11.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "posthog-js": "^1.372.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260424.1",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4",
    "@types/node": "25.6.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "beasties": "^0.3.5",
    "tailwindcss": "4",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite": "^6.0.0",
    "vitest": "4.1.5",
    "wrangler": "4.85.0"
  }
}

---
import '@/styles/landing.css';
import '@fontsource-variable/inter';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const SITE_URL = 'https://truehire.sarthakagrawal927.workers.dev';
const _OG_IMAGE = `${SITE_URL}/opengraph-image`;

const _NAV_LINKS = [
  { href: '/#how', label: 'How it works' },
  { href: '/#signals', label: 'Signals' },
  { href: '/recruiter/shortlist', label: 'Recruiters' },
  { href: '/#faq', label: 'FAQ' },
];
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content="TrueHire" />

    <link rel="canonical" href={SITE_URL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:site_name" content="TrueHire" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={OG_IMAGE} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />

    {/* ── Fonts ────────────────────────────────────────────────────
       The body face is system-ui first with Inter as a webfont layer
       — Inter is the only LCP-critical face (the hero H1 lives in the
       body sans). Self-hosted via @fontsource-variable/inter (imported
       in the frontmatter). Astro/Vite extracts the @font-face into the
       page CSS and serves the woff2 from /_astro/ same-origin, so there
       is no external CSS fetch on the LCP path. font-display: swap is
       preserved by Fontsource. JetBrains Mono is NOT loaded: the `.num`
       rule falls through to ui-monospace cleanly and the `.num` glyphs
       don't appear above the fold on mobile. */}
  </head>
  <body class="min-h-full flex flex-col bg-[var(--background)] text-[var(--foreground)]">
    {/* ─────────────────────  HEADER  ─────────────────────
       Static signed-out variant of `src/components/organisms/site-header.tsx`.
       The original is a "use client" component reading next-auth session
       state — but the static landing renders for anon users only (the
       Worker short-circuits to OpenNext when an auth cookie is present),
       so we can safely bake in the signed-out shape. */}
    <header class="sticky top-0 z-40 border-b border-[var(--border)] bg-[color-mix(in_srgb,var(--background)_85%,transparent)] backdrop-blur-xl">
      <div class="mx-auto flex h-14 w-full max-w-6xl items-center justify-between gap-4 px-4 sm:px-6">
        <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
          <span
            class="relative inline-flex h-6 w-6 items-center justify-center rounded-[6px] bg-[var(--foreground)] text-[var(--background)]"
            aria-hidden="true"
          >
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none">
              <path d="M5 13l4 4 10-10" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span>TrueHire</span>
        </a>

        <nav class="hidden items-center gap-6 text-sm text-[var(--muted)] md:flex">
          {NAV_LINKS.map((l) => (
            <a href={l.href} class="hover:text-[var(--foreground)]">{l.label}</a>
          ))}
        </nav>

        <div class="flex items-center gap-2">
          <a href="/login" class="inline-flex h-8 items-center justify-center gap-2 whitespace-nowrap rounded-[var(--radius-sm)] bg-[var(--accent)] px-3 text-[13px] font-medium text-[var(--accent-contrast)] transition-opacity hover:opacity-90">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.744.084-.729.084-.729 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.605-2.665-.305-5.467-1.334-5.467-5.93 0-1.31.468-2.381 1.236-3.22-.124-.303-.536-1.524.118-3.176 0 0 1.007-.322 3.3 1.23a11.52 11.52 0 0 1 3-.404c1.02.005 2.046.137 3.006.404 2.29-1.552 3.296-1.23 3.296-1.23.654 1.652.242 2.873.118 3.176.77.839 1.236 1.91 1.236 3.22 0 4.61-2.807 5.624-5.48 5.921.43.372.816 1.102.816 2.22 0 1.604-.015 2.896-.015 3.29 0 .322.216.697.825.579C20.565 22.092 24 17.598 24 12.297c0-6.627-5.373-12-12-12" />
            </svg>
            Sign in
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    {/* ─────────────────────  FOOTER  ─────────────────────
       Static port of `src/components/organisms/site-footer.tsx`. */}
    <footer class="mt-24 border-t border-[var(--border)]">
      <div class="mx-auto grid w-full max-w-6xl gap-6 px-6 py-10 md:grid-cols-3">
        <div class="text-sm text-[var(--muted)]">
          <div class="mb-2 text-[var(--foreground)] font-medium">TrueHire</div>
          The verified-candidate layer. Costly signals, not tailored resumes.
        </div>
        <div class="text-sm">
          <div class="mb-2 text-[11px] uppercase tracking-[0.1em] text-[var(--muted-2)]">Product</div>
          <ul class="space-y-1 text-[var(--muted)]">
            <li><a href="/#signals" class="hover:text-[var(--foreground)]">Signal stack</a></li>
            <li><a href="/#how" class="hover:text-[var(--foreground)]">Scoring methodology</a></li>
            <li><a href="/#faq" class="hover:text-[var(--foreground)]">FAQ</a></li>
          </ul>
        </div>
        <div class="text-sm">
          <div class="mb-2 text-[11px] uppercase tracking-[0.1em] text-[var(--muted-2)]">Legal</div>
          <ul class="space-y-1 text-[var(--muted)]">
            <li><a href="/privacy" class="hover:text-[var(--foreground)]">Privacy</a></li>
            <li><a href="/terms" class="hover:text-[var(--foreground)]">Terms</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-[var(--border)]">
        <div class="mx-auto w-full max-w-6xl px-6 py-4 text-[11px] text-[var(--muted-2)]">
          © 2026 TrueHire — derived, not declared.
        </div>
      </div>
    </footer>
  </body>
</html>
